 # Project include/libraries
+# On macOS (case-insensitive FS) OpenFOAM's .H files (Time.H, wchar.H, etc.)
+# shadow POSIX headers when using -I. Use -iquote so these dirs are only searched
+# for quoted "#include" forms, never for angle-bracket system includes.
 PROJECT_INC     = \
-    -I$(LIB_SRC)/$(WM_PROJECT)/lnInclude \
-    -I$(LIB_SRC)/OSspecific/$(WM_OSTYPE)/lnInclude
+    -iquote $(LIB_SRC)/$(WM_PROJECT)/lnInclude \
